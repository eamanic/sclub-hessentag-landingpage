# S-Club Hessentag-Landingpage
# Das HEUTE-Special wechselt täglich → HTML/JS/CSS dürfen nicht stale gecacht
# werden. no-cache erzwingt Revalidierung (ETag/Last-Modified → 304 wenn
# unverändert, frischer Download wenn geändert).
<IfModule mod_headers.c>
  <FilesMatch "\.(html?|js|css)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# Fallback für Server ohne mod_headers
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType application/javascript "access plus 0 seconds"
  ExpiresByType text/css "access plus 0 seconds"
</IfModule>

# index.html als Standard-Dokument (vor der All-Inkl-Platzhalter-index.htm)
DirectoryIndex index.html index.htm
